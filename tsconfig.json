{
  "compilerOptions": {
    "target": "es6",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
        "@data/*": ["./data/*"],
        "@pages/*": ["./pages/*"],
        "@utils/*": ["./utils/*"],
        "@fixtures/*": ["./fixtures/*"],
        "@models/*": ["./models/*"],
        "@tests/*": ["./tests/*"],
        "@data/*": ["./data/*"],
        "@common-components/*": ["./pages/common-components/*"],
    }
  },
}