{
    "baseUrl": "https://example.com/api",
    "endpoints": [
        {
            "name": "getUser",
            "method": "GET",
            "path": "/users/{id}",
            "description": "Fetch a user by ID"
        },
        {
            "name": "createUser",
            "method": "POST",
            "path": "/users",
            "description": "Create a new user"
        },
        {
            "name": "updateUser",
            "method": "PUT",
            "path": "/users/{id}",
            "description": "Update an existing user"
        },
        {
            "name": "deleteUser",
            "method": "DELETE",
            "path": "/users/{id}",
            "description": "Delete a user by ID"
        }
    ]
}